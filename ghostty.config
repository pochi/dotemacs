# Ghostty Configuration
# https://ghostty.org/docs

# ===== Clipboard Settings =====

# Enable OSC 52 clipboard integration
clipboard-read = allow
clipboard-write = allow

# Use system clipboard for OSC 52
clipboard-paste-protection = false

# ===== Terminal Settings =====

# True color support
term = xterm-256color

# Font configuration
# font-family = "Monaspace Neon"
# font-size = 14

# ===== macOS Integration =====

# Enable macOS keybindings
macos-option-as-alt = true

# Window settings
window-padding-x = 4
window-padding-y = 4

# Theme (optional)
# theme = dark
